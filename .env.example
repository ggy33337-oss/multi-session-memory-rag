APP_HOST=127.0.0.1
APP_PORT=8000

DATABASE_URL=postgresql://memory_user:memory_password@127.0.0.1:5432/memory_rag

DOCUMENT_DIR=data/documents/uploads

RECENT_TURNS=5
RETRIEVE_TOP_K=3
DOCUMENT_RETRIEVE_TOP_K=3
DOCUMENT_CHUNK_SIZE=700
DOCUMENT_CHUNK_OVERLAP=100
DOCUMENT_SIMILARITY_THRESHOLD=0.35

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSION=1024

LLM_PROVIDER=openai
LLM_MODEL=qwen-plus

